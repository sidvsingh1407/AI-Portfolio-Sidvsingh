{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A contact form message submission",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The sender's name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The sender's email address"
        },
        "message": {
          "type": "string",
          "description": "The message content"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the message was sent"
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of contact form messages"
    }
  }
}
